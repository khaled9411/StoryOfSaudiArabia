    options:
    - "\u0627\u0644\u0625\u0645\u0627\u0645 \u0627\u0644\u0634\u0627\u0641\u0639\u064A"
    - "\u0627\u0644\u0634\u064A\u062E \u0645\u062D\u0645\u062F \u0628\u0646 \u0639\u0628\u062F
      \u0627\u0644\u0648\u0647\u0627\u0628"
    - "\u0627\u0644\u0645\u0644\u0643 \u0639\u0628\u062F \u0627\u0644\u0639\u0632\u064A\u0632
      \u0622\u0644 \u0633\u0639\u0648\u062F"
    - "\u0627\u0644\u0625\u0645\u0627\u0645 \u062A\u0631\u0643\u064A \u0628\u0646
      \u0639\u0628\u062F \u0627\u0644\u0644\u0647"
    correctAnswerIndex: 1
    hintText: "\u0646\u0641\u0633 \u0627\u0644\u0634\u062E\u0635 \u0627\u0644\u0644\u064A
