  questionData:
    questionText: "\u0645\u0627 \u0627\u0644\u0647\u062F\u0641 \u0645\u0646 \u0642\u064A\u0627\u0645
      \u0627\u0644\u062F\u0648\u0644\u0629 \u0627\u0644\u0633\u0639\u0648\u062F\u064A\u0629
      \u0627\u0644\u0623\u0648\u0644\u0649\u061F"
    options:
    - "\u0627\u0644\u062A\u0648\u0633\u0639 \u0627\u0644\u062A\u062C\u0627\u0631\u064A"
    - "\u0627\u0644\u0633\u064A\u0637\u0631\u0629 \u0639\u0644\u0649 \u0637\u0631\u0642
      \u0627\u0644\u062A\u062C\u0627\u0631\u0629 \u0627\u0644\u0639\u0627\u0644\u0645\u064A\u0629"
    - "\u0628\u0646\u0627\u0621 \u0625\u0645\u0628\u0631\u0627\u0637\u0648\u0631\u064A\u0629
      \u0641\u064A \u0627\u0644\u0645\u0646\u0637\u0642\u0629"
    - "\u062A\u0648\u062D\u064A\u062F \u0627\u0644\u0628\u0644\u0627\u062F \u0648\u0646\u0634\u0631
      \u0627\u0644\u062A\u0648\u062D\u064A\u062F \u0648\u0627\u0644\u0625\u0635\u0644\u0627\u062D"
    correctAnswerIndex: 3
    hintText: "\u0634\u064A\u0626\u064A\u0646: \u062F\u064A\u0646\u064A \u0648\u0633\u064A\u0627\u0633\u064A
