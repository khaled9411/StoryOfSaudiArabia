  questionData:
    questionText: "\u0645\u0627 \u0633\u0628\u0628 \u0636\u0639\u0641 \u0627\u0644\u062F\u0648\u0644\u0629
      \u0627\u0644\u0633\u0639\u0648\u062F\u064A\u0629 \u0627\u0644\u062B\u0627\u0646\u064A\u0629\u061F"
    options:
    - "\u0642\u0644\u0629 \u0627\u0644\u0645\u0648\u0627\u0631\u062F \u0627\u0644\u0637\u0628\u064A\u0639\u064A\u0629"
    - "\u0627\u0644\u062D\u0631\u0648\u0628 \u0645\u0639 \u0627\u0644\u062F\u0648\u0644\u0629
      \u0627\u0644\u0639\u062B\u0645\u0627\u0646\u064A\u0629 \u0628\u0634\u0643\u0644
      \u0645\u0628\u0627\u0634\u0631"
    - "\u0645\u0634\u0627\u0643\u0644 \u062F\u0627\u062E\u0644 \u0627\u0644\u0639\u0627\u0626\u0644\u0629"
    - "\u0627\u0644\u0627\u0633\u062A\u0642\u0631\u0627\u0631 \u0627\u0644\u0633\u064A\u0627\u0633\u064A
      \u0644\u0641\u062A\u0631\u0629 \u0637\u0648\u064A\u0644\u0629"
    correctAnswerIndex: 2
    hintText: "\u0627\u0644\u062E\u0644\u0627\u0641\u0627\u062A \u0628\u064A\u0646
      \u0623\u0628\u0646\u0627\u0621 \u0627\u0644\u0625\u0645\u0627\u0645 \u0641\u064A\u0635\u0644
      \u0628\u0646 \u062A\u0631\u0643\u064A"
