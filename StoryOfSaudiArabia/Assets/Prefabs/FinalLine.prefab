  questionData:
    questionText: "\u0645\u0646 \u0647\u0648 \u0645\u0624\u0633\u0633 \u0627\u0644\u062F\u0648\u0644\u0629
      \u0627\u0644\u0633\u0639\u0648\u062F\u064A\u0629 \u0627\u0644\u0623\u0648\u0644\u0649\u061F"
    options:
    - "\u0627\u0644\u0645\u0644\u0643 \u0639\u0628\u062F \u0627\u0644\u0639\u0632\u064A\u0632
      \u0622\u0644 \u0633\u0639\u0648\u062F"
    - "\u0645\u062D\u0645\u062F \u0639\u0644\u064A \u0628\u0627\u0634\u0627"
    - "\u0627\u0644\u0625\u0645\u0627\u0645 \u0645\u062D\u0645\u062F \u0628\u0646
      \u0633\u0639\u0648\u062F"
    - "\u0627\u0644\u0645\u0644\u0643 \u0641\u064A\u0635\u0644 \u0628\u0646 \u0639\u0628\u062F
      \u0627\u0644\u0639\u0632\u064A\u0632"
    correctAnswerIndex: 2
    hintText: " \u0627\u0633\u0645\u0647 \u064A\u0628\u062F\u0623 \u0628\u0640 \u201C\u0645\u062D\u0645\u062F\u201D
